{
	"edit_predictions": {
		"provider": "copilot",
		"mode": "eager",
		"disabled_globs": [
			"**/node_modules/**",
			"**/dist/**",
			"**/.venv/**",
			"**/__pycache__/**"
		]
	},

	"agent": {
		"default_profile": "write",
		"play_sound_when_agent_done": true,
		"default_model": {
			"provider": "copilot_chat",
			"model": "claude-sonnet-4.6",
			"enable_thinking": false
		},
		"favorite_models": [
			{
				"model": "claude-sonnet-4.6",
				"provider": "copilot_chat"
			},
			{
				"model": "claude-sonnet-4.5",
				"provider": "copilot_chat"
			},
			{
				"model": "claude-sonnet-4",
				"provider": "copilot_chat"
			},
			{
				"model": "GPT-5.3-Codex",
				"provider": "copilot_chat"
			},
			{
				"model": "GPT-5.2-Codex",
				"provider": "copilot_chat"
			}
		],
		"model_parameters": []
	},
	"project_panel": {
		"auto_fold_dirs": false
	},
	"base_keymap": "VSCode",
	"file_types": {
		"tailwindcss": ["*.css"]
	},
	"soft_wrap": "editor_width",
	"ui_font_size": 16,
	"buffer_font_size": 17.0,
	"theme": {
		"mode": "system",
		"light": "Ayu Light",
		"dark": "Ayu Dark"
	},
	"icon_theme": "Material Icon Theme",
	"prettier": {
		"allowed": true
	},
	"formatter": "prettier",
	"jsx_tag_auto_close": {
		"enabled": true
	}
}
